    "jsonwebtoken": "^9.0.3",
    "dotenv": "^17.3.1",
    "body-parser": "^1.20.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/body-parser": "^1.19.5",
    "typescript": "^5.0.0"
