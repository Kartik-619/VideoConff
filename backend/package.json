{
  "name": "videoconff-backend",
  "version": "1.0.0",
  "description": "VideoConff WebSocket Signaling Server",
  "main": "signaling/server.js",
  "scripts": {
    "start": "npm run build && node signaling/server.js",
    "build": "tsc signaling/server.ts --outDir . --target es2020 --module commonjs --skipLibCheck"
  },
  "dependencies": {
    "express": "^5.2.1",
    "ws": "^8.18.0",
    "mediasoup": "^3.19.17",
